# Database
# DATABASE_URL=postgresql://pharmatrack:pharmatrack@localhost:5432/pharmatrack

# Redis
REDIS_URL=redis://localhost:6379

# Auth (better-auth)
AUTH_SECRET=change-me-to-a-random-32-char-string
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp
# WHATSAPP_ADAPTER=mock (default) | meta
WHATSAPP_ADAPTER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# App URL (used to generate patient address links)
APP_URL=http://localhost:3000

# AWS (S3)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Resend — transactional email (OTP fallback)
# Get API key from resend.com. Verify pharmatrack.mrohadi.com domain there.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@pharmatrack.mrohadi.com
# Set to 'true' in dev to force email fallback even when WhatsApp succeeds
FORCE_EMAIL_FALLBACK=false

# S3
S3_BUCKET=pharmatrack
S3_REGION=ap-southeast-1

# App
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:3000

# Cron (shared secret for cron endpoints)
# Set this to a random string. Cron caller must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-to-a-random-secret

# Reminder settings (optional, defaults shown)
REMINDER_INTERVAL_HOURS=6
REMINDER_MAX_COUNT=2

# Admin report email — receives daily digest
ADMIN_REPORT_EMAIL=admin@pharmatrack.mrohadi.com

# Auto-assign driver (set to true to enable)
AUTO_ASSIGN_DRIVER=false
