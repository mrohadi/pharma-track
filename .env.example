# Database
DATABASE_URL=postgresql://pharmatrack:pharmatrack@localhost:5432/pharmatrack

# Redis
REDIS_URL=redis://localhost:6379

# Auth (better-auth)
AUTH_SECRET=local-dev-secret-at-least-32-chars-long-xxx
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# WhatsApp
# WHATSAPP_ADAPTER=mock (default) | meta
WHATSAPP_ADAPTER=mock
WHATSAPP_PHONE_NUMBER_ID=phonenumberid
WHATSAPP_ACCESS_TOKEN=AccessToken
WHATSAPP_VERIFY_TOKEN=VerifyToken
WHATSAPP_APP_SECRET=AppSecret

TWILIO_ACCOUNT_SID=accountsid
TWILIO_AUTH_TOKEN=authtoken
TWILIO_WHATSAPP_FROM=+1234567890

# Twilio Message Template
TWILIO_SID_ADDRESS_COLLECTION_OTP_V1=SID for address collection OTP template

# AWS (S3)
AWS_ACCESS_KEY_ID=accesskey
AWS_SECRET_ACCESS_KEY=secretkey
S3_BUCKET=pharmatracks
S3_REGION=ap-southeast-1

# Resend — transactional email (OTP fallback)
# Get API key from resend.com. Verify pharmatrack.mrohadi.com domain there.
RESEND_API_KEY=apikey
RESEND_FROM_EMAIL=noreply@admin.com
FORCE_EMAIL_FALLBACK=false

# Cron (shared secret for cron endpoints)
# Set this to a random string. Cron caller must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-to-a-random-secret

# Reminder settings (optional, defaults shown)
REMINDER_INTERVAL_HOURS=6
REMINDER_MAX_COUNT=2

# Admin report email — receives daily digest
ADMIN_REPORT_EMAIL=admin@test.com

# Auto-assign driver (set to true to enable)
AUTO_ASSIGN_DRIVER=false
