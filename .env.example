# Database
DATABASE_URL=postgresql://pharmatrack:pharmatrack@localhost:5432/pharmatrack

# Redis
REDIS_URL=redis://localhost:6379

# Auth (better-auth)
AUTH_SECRET=change-me-to-a-random-32-char-string
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp
# WHATSAPP_ADAPTER=mock (default) | meta
WHATSAPP_ADAPTER=mock
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# App URL (used to generate patient address links)
APP_URL=http://localhost:3000

# AWS (SES + S3)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SES_FROM_EMAIL=

# S3 — LocalStack for dev, real S3 for prod
S3_BUCKET=pharmatrack-uploads
S3_REGION=ap-southeast-1
# Set S3_ENDPOINT for local dev (LocalStack). Remove or leave empty for prod (real S3).
S3_ENDPOINT=http://localhost:4566

# App
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:3000
